generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model allowances {
  id          BigInt    @id @default(autoincrement())
  uuid        String    @unique(map: "Allowances_uuid_key") @db.Char(36)
  employee_id BigInt
  title       String    @db.VarChar(100)
  amount      Decimal   @default(0.00) @db.Decimal(18, 2)
  description String?   @db.Text
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime
  employees   employees @relation(fields: [employee_id], references: [id], map: "Allowances_employee_id_fkey")

  @@index([is_active], map: "idx_allowance_active")
  @@index([employee_id], map: "idx_allowance_employee")
}

model approval_request_actions {
  id                  BigInt                          @id @default(autoincrement())
  approval_request_id BigInt
  step_order          Int
  action_by           BigInt
  action              approval_request_actions_action
  comment             String?                         @db.Text
  action_at           DateTime                        @default(now())
  users               users                           @relation(fields: [action_by], references: [id], map: "Approval_request_actions_action_by_fkey")
  approval_requests   approval_requests               @relation(fields: [approval_request_id], references: [id], map: "Approval_request_actions_approval_request_id_fkey")

  @@index([action_by], map: "Approval_request_actions_action_by_fkey")
  @@index([approval_request_id], map: "idx_approval_action_request")
}

model approval_requests {
  id                       BigInt                     @id @default(autoincrement())
  uuid                     String                     @unique(map: "Approval_requests_uuid_key") @db.Char(36)
  workflow_id              BigInt
  reference_table          String                     @db.VarChar(100)
  reference_id             BigInt
  current_step             Int
  status                   approval_requests_status
  initiated_by             BigInt
  created_at               DateTime                   @default(now())
  approval_request_actions approval_request_actions[]
  users                    users                      @relation(fields: [initiated_by], references: [id], map: "Approval_requests_initiated_by_fkey")
  approval_workflows       approval_workflows         @relation(fields: [workflow_id], references: [id], map: "Approval_requests_workflow_id_fkey")

  @@index([initiated_by], map: "Approval_requests_initiated_by_fkey")
  @@index([status], map: "idx_approval_request_status")
  @@index([workflow_id], map: "idx_approval_request_workflow")
}

model approval_workflow_steps {
  id                 BigInt             @id @default(autoincrement())
  workflow_id        BigInt
  step_order         Int
  department_id      BigInt
  role_id            BigInt
  can_approve        Boolean            @default(true)
  can_reject         Boolean            @default(true)
  created_at         DateTime           @default(now())
  departments        departments        @relation(fields: [department_id], references: [id], map: "Approval_workflow_steps_department_id_fkey")
  roles              roles              @relation(fields: [role_id], references: [id], map: "Approval_workflow_steps_role_id_fkey")
  approval_workflows approval_workflows @relation(fields: [workflow_id], references: [id], map: "Approval_workflow_steps_workflow_id_fkey")

  @@index([department_id], map: "Approval_workflow_steps_department_id_fkey")
  @@index([role_id], map: "Approval_workflow_steps_role_id_fkey")
  @@index([workflow_id], map: "idx_workflow_step_workflow")
}

model approval_workflows {
  id                      BigInt                         @id @default(autoincrement())
  uuid                    String                         @unique(map: "Approval_workflows_uuid_key") @db.Char(36)
  workflow_name           String                         @db.VarChar(150)
  module_name             approval_workflows_module_name
  is_active               Boolean                        @default(true)
  created_at              DateTime                       @default(now())
  approval_requests       approval_requests[]
  approval_workflow_steps approval_workflow_steps[]

  @@index([is_active], map: "idx_workflow_active")
}

model audit_logs {
  id                   BigInt                   @id @default(autoincrement())
  user_id              BigInt
  employee_id          BigInt?
  entity_table         String                   @db.VarChar(150)
  entity_id            BigInt
  module_name          String                   @db.VarChar(100)
  activity_type        audit_logs_activity_type
  activity_description String                   @db.Text
  action               audit_logs_action
  old_values           Json?
  new_values           Json?
  changed_fields       Json?
  ip_address           String?                  @db.VarChar(100)
  created_at           DateTime                 @default(now())
  employees            employees?               @relation(fields: [employee_id], references: [id], map: "Audit_logs_employee_id_fkey")
  users                users                    @relation(fields: [user_id], references: [id], map: "Audit_logs_user_id_fkey")

  @@index([employee_id], map: "Audit_logs_employee_id_fkey")
  @@index([action], map: "idx_audit_action")
  @@index([created_at], map: "idx_audit_created")
  @@index([entity_id], map: "idx_audit_entity_id")
  @@index([entity_table], map: "idx_audit_entity_table")
  @@index([user_id], map: "idx_audit_user")
}

model branch_managers {
  id                                       BigInt            @id @default(autoincrement())
  uuid                                     String            @unique(map: "Branch_managers_uuid_key") @db.Char(36)
  working_location_id                      BigInt
  user_id                                  BigInt
  is_active                                Boolean           @default(true)
  assigned_at                              DateTime          @default(now())
  unassigned_at                            DateTime?
  assigned_by                              BigInt
  users_branch_managers_assigned_byTousers users             @relation("branch_managers_assigned_byTousers", fields: [assigned_by], references: [id], map: "Branch_managers_assigned_by_fkey")
  users_branch_managers_user_idTousers     users             @relation("branch_managers_user_idTousers", fields: [user_id], references: [id], map: "Branch_managers_user_id_fkey")
  working_locations                        working_locations @relation(fields: [working_location_id], references: [id], map: "Branch_managers_working_location_id_fkey")

  @@index([assigned_by], map: "Branch_managers_assigned_by_fkey")
  @@index([is_active], map: "idx_branch_manager_active")
  @@index([working_location_id], map: "idx_branch_manager_location")
  @@index([user_id], map: "idx_branch_manager_user")
}

model deduction_types {
  id                  BigInt                         @id @default(autoincrement())
  uuid                String                         @unique(map: "Deduction_types_uuid_key") @db.Char(36)
  name                String                         @unique(map: "Deduction_types_name_key") @db.VarChar(100)
  deduction_mode      deduction_types_deduction_mode
  amount              Decimal                        @default(0.00) @db.Decimal(18, 2)
  percentage_value    Decimal                        @default(0.00) @db.Decimal(5, 2)
  is_mandatory        Boolean                        @default(false)
  created_at          DateTime                       @default(now())
  updated_at          DateTime
  employee_deductions employee_deductions[]
}

model departments {
  id                                                               BigInt                    @id @default(autoincrement())
  uuid                                                             String                    @unique(map: "Departments_uuid_key") @db.Char(36)
  working_location_id                                              BigInt
  code                                                             String                    @db.VarChar(20)
  name                                                             String                    @db.VarChar(100)
  description                                                      String?                   @db.Text
  status                                                           departments_status        @default(ACTIVE)
  created_at                                                       DateTime                  @default(now())
  updated_at                                                       DateTime
  approval_workflow_steps                                          approval_workflow_steps[]
  working_locations                                                working_locations         @relation(fields: [working_location_id], references: [id], map: "Departments_working_location_id_fkey")
  employee_history_employee_history_new_department_idTodepartments employee_history[]        @relation("employee_history_new_department_idTodepartments")
  employee_history_employee_history_old_department_idTodepartments employee_history[]        @relation("employee_history_old_department_idTodepartments")
  employees                                                        employees[]
  user_departments                                                 user_departments[]
  users                                                            users[]
  time_records                                                      time_records[]
  transactions                                                      transactions[]
  ikimina_memberships                                               ikimina_memberships[]

  @@unique([working_location_id, code], map: "Departments_working_location_id_code_key")
  @@unique([working_location_id, name], map: "Departments_working_location_id_name_key")
  @@index([working_location_id], map: "idx_department_location")
}

model employee_deductions {
  id                BigInt          @id @default(autoincrement())
  uuid              String          @unique(map: "Employee_deductions_uuid_key") @db.Char(36)
  employee_id       BigInt
  deduction_type_id BigInt
  start_date        DateTime        @db.Date
  end_date          DateTime?
  is_active         Boolean         @default(true)
  created_at        DateTime        @default(now())
  deduction_types   deduction_types @relation(fields: [deduction_type_id], references: [id], map: "Employee_deductions_deduction_type_id_fkey")
  employees         employees       @relation(fields: [employee_id], references: [id], map: "Employee_deductions_employee_id_fkey")

  @@index([employee_id], map: "idx_employee_deduction_employee")
  @@index([deduction_type_id], map: "idx_employee_deduction_type")
}

model employee_documents {
  id          BigInt    @id @default(autoincrement())
  uuid        String    @unique(map: "Employee_documents_uuid_key") @db.Char(36)
  employee_id BigInt
  file_name   String    @db.VarChar(255)
  file_path   String    @db.Text
  uploaded_by BigInt
  created_at  DateTime  @default(now())
  employees   employees @relation(fields: [employee_id], references: [id], map: "Employee_documents_employee_id_fkey")
  users       users     @relation(fields: [uploaded_by], references: [id], map: "Employee_documents_uploaded_by_fkey")

  @@index([uploaded_by], map: "Employee_documents_uploaded_by_fkey")
  @@index([employee_id], map: "idx_employee_document_employee")
}

model employee_history {
  id                                                                                       BigInt                       @id @default(autoincrement())
  uuid                                                                                     String                       @unique(map: "Employee_history_uuid_key") @db.Char(36)
  employee_id                                                                              BigInt
  action_type                                                                              employee_history_action_type
  old_department_id                                                                        BigInt?
  new_department_id                                                                        BigInt?
  old_location_id                                                                          BigInt?
  new_location_id                                                                          BigInt?
  old_employment_category_id                                                               BigInt?
  new_employment_category_id                                                               BigInt?
  status                                                                                   employee_history_status
  reason                                                                                   String?                      @db.Text
  changed_by                                                                               BigInt
  approved_by                                                                              BigInt
  created_at                                                                               DateTime                     @default(now())
  users_employee_history_approved_byTousers                                                users                        @relation("employee_history_approved_byTousers", fields: [approved_by], references: [id], map: "Employee_history_approved_by_fkey")
  users_employee_history_changed_byTousers                                                 users                        @relation("employee_history_changed_byTousers", fields: [changed_by], references: [id], map: "Employee_history_changed_by_fkey")
  employees                                                                                employees                    @relation(fields: [employee_id], references: [id], map: "Employee_history_employee_id_fkey")
  departments_employee_history_new_department_idTodepartments                              departments?                 @relation("employee_history_new_department_idTodepartments", fields: [new_department_id], references: [id], map: "Employee_history_new_department_id_fkey")
  employment_categories_employee_history_new_employment_category_idToemployment_categories employment_categories?       @relation("employee_history_new_employment_category_idToemployment_categories", fields: [new_employment_category_id], references: [id], map: "Employee_history_new_employment_category_id_fkey")
  working_locations_employee_history_new_location_idToworking_locations                    working_locations?           @relation("employee_history_new_location_idToworking_locations", fields: [new_location_id], references: [id], map: "Employee_history_new_location_id_fkey")
  departments_employee_history_old_department_idTodepartments                              departments?                 @relation("employee_history_old_department_idTodepartments", fields: [old_department_id], references: [id], map: "Employee_history_old_department_id_fkey")
  employment_categories_employee_history_old_employment_category_idToemployment_categories employment_categories?       @relation("employee_history_old_employment_category_idToemployment_categories", fields: [old_employment_category_id], references: [id], map: "Employee_history_old_employment_category_id_fkey")
  working_locations_employee_history_old_location_idToworking_locations                    working_locations?           @relation("employee_history_old_location_idToworking_locations", fields: [old_location_id], references: [id], map: "Employee_history_old_location_id_fkey")

  @@index([approved_by], map: "Employee_history_approved_by_fkey")
  @@index([changed_by], map: "Employee_history_changed_by_fkey")
  @@index([new_department_id], map: "Employee_history_new_department_id_fkey")
  @@index([new_employment_category_id], map: "Employee_history_new_employment_category_id_fkey")
  @@index([new_location_id], map: "Employee_history_new_location_id_fkey")
  @@index([old_department_id], map: "Employee_history_old_department_id_fkey")
  @@index([old_employment_category_id], map: "Employee_history_old_employment_category_id_fkey")
  @@index([old_location_id], map: "Employee_history_old_location_id_fkey")
  @@index([employee_id], map: "idx_employee_history_employee")
}

model employees {
  id                     BigInt                  @id @default(autoincrement())
  uuid                   String                  @unique(map: "Employees_uuid_key") @db.Char(36)
  first_name             String                  @db.VarChar(100)
  last_name              String                  @db.VarChar(100)
  email                  String?                 @unique(map: "Employees_email_key") @db.VarChar(150)
  phone_number           String?                 @unique(map: "Employees_phone_number_key") @db.VarChar(15)
  national_id            String?                 @unique(map: "Employees_national_id_key") @db.VarChar(16)
  gender                 person_gender?
  hire_date              DateTime?               @db.Date
  contract_start_date    DateTime?               @db.Date
  contract_end_date      DateTime?               @db.Date
  department_id          BigInt?
  working_location_id    BigInt?
  employment_category_id BigInt?
  status                 employees_status        @default(ACTIVE)
  pause_reason           String?                 @db.VarChar(255)
  created_by             BigInt?
  avatar_url             String?                 @db.Text
  created_at             DateTime                @default(now())
  updated_at             DateTime
  deleted_at             DateTime?
  allowances             allowances[]
  audit_logs             audit_logs[]
  employee_deductions    employee_deductions[]
  employee_documents     employee_documents[]
  employee_history       employee_history[]
  users                  users?                  @relation(fields: [created_by], references: [id], map: "Employees_created_by_fkey")
  departments            departments?            @relation(fields: [department_id], references: [id], map: "Employees_department_id_fkey")
  employment_categories  employment_categories?  @relation(fields: [employment_category_id], references: [id], map: "Employees_employment_category_id_fkey")
  working_locations      working_locations?      @relation(fields: [working_location_id], references: [id], map: "Employees_working_location_id_fkey")
  ikimina_contributions  ikimina_contributions[]
  ikimina_memberships    ikimina_memberships?
  payment_batch_items    payment_batch_items[]
  payment_structures     payment_structures[]
  time_records           time_records[]
  transactions           transactions[]
  transfer_requests      transfer_requests[]

  @@unique([first_name, last_name, working_location_id, department_id], map: "Employees_first_name_last_name_working_location_id_departmen_key")
  @@index([employment_category_id], map: "idx_employee_category")
  @@index([created_by], map: "idx_employee_created_by")
  @@index([deleted_at], map: "idx_employee_deleted_at")
  @@index([department_id], map: "idx_employee_department")
  @@index([email], map: "idx_employee_email")
  @@index([first_name], map: "idx_employee_first_name")
  @@index([last_name], map: "idx_employee_last_name")
  @@index([working_location_id], map: "idx_employee_location")
  @@index([national_id], map: "idx_employee_national_id")
  @@index([phone_number], map: "idx_employee_phone")
  @@index([status], map: "idx_employee_status")
  @@index([uuid], map: "idx_employee_uuid")
}

model employment_categories {
  id                                                                                  BigInt                                  @id @default(autoincrement())
  uuid                                                                                String                                  @unique(map: "Employment_categories_uuid_key") @db.Char(36)
  name                                                                                String                                  @unique(map: "Employment_categories_name_key") @db.VarChar(100)
  payroll_frequency                                                                   employment_categories_payroll_frequency
  tax_behavior                                                                        employment_categories_tax_behavior
  description                                                                         String?                                 @db.Text
  status                                                                              employment_categories_status            @default(ACTIVE)
  created_at                                                                          DateTime                                @default(now())
  updated_at                                                                          DateTime
  employee_history_employee_history_new_employment_category_idToemployment_categories employee_history[]                      @relation("employee_history_new_employment_category_idToemployment_categories")
  employee_history_employee_history_old_employment_category_idToemployment_categories employee_history[]                      @relation("employee_history_old_employment_category_idToemployment_categories")
  employees                                                                           employees[]
}

model ikimina_contributions {
  id                  BigInt              @id @default(autoincrement())
  uuid                String              @unique(map: "Ikimina_contributions_uuid_key") @db.Char(36)
  employee_id         BigInt
  membership_id       BigInt
  payroll_batch_id    BigInt?
  amount              Decimal             @default(0.00) @db.Decimal(18, 2)
  contribution_date   DateTime            @default(now())
  created_at          DateTime            @default(now())
  employees           employees           @relation(fields: [employee_id], references: [id], map: "Ikimina_contributions_employee_id_fkey")
  ikimina_memberships ikimina_memberships @relation(fields: [membership_id], references: [id], map: "Ikimina_contributions_membership_id_fkey")
  payment_batches     payment_batches?    @relation(fields: [payroll_batch_id], references: [id], map: "Ikimina_contributions_payroll_batch_id_fkey")

  @@unique([employee_id, payroll_batch_id], map: "Ikimina_contributions_employee_id_payroll_batch_id_key")
  @@index([payroll_batch_id], map: "idx_ikimina_contribution_batch")
  @@index([employee_id], map: "idx_ikimina_contribution_employee")
  @@index([membership_id], map: "idx_ikimina_contribution_membership")
}

model ikimina_memberships {
  id                    BigInt                  @id @default(autoincrement())
  uuid                  String                  @unique(map: "Ikimina_memberships_uuid_key") @db.Char(36)
  employee_id           BigInt                  @unique(map: "Ikimina_memberships_employee_id_key")
  monthly_amount        Decimal                 @default(0.00) @db.Decimal(18, 2)
  is_active             Boolean                 @default(true)
  joined_at             DateTime                @default(now())
  created_by            BigInt
  working_location_id   BigInt?
  department_id         BigInt?
  created_at            DateTime                @default(now())
  updated_at            DateTime
  ikimina_contributions ikimina_contributions[]
  employees             employees               @relation(fields: [employee_id], references: [id], map: "Ikimina_memberships_employee_id_fkey")
  working_locations     working_locations?      @relation("ikimina_memberships_working_locationToworking_locations", fields: [working_location_id], references: [id], map: "Ikimina_memberships_working_location_id_fkey")
  departments           departments?            @relation(fields: [department_id], references: [id], map: "Ikimina_memberships_department_id_fkey")

  @@index([is_active], map: "idx_ikimina_membership_active")
  @@index([employee_id], map: "idx_ikimina_membership_employee")
  @@index([working_location_id], map: "idx_ikimina_membership_location")
  @@index([department_id], map: "idx_ikimina_membership_department")
}

model monthly_taxes {
  id             BigInt   @id @default(autoincrement())
  uuid           String   @unique(map: "Monthly_taxes_uuid_key") @db.Char(36)
  name           String   @db.VarChar(100)
  rate           Decimal  @db.Decimal(5, 2)
  effective_from DateTime @db.Date
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime

  @@index([is_active], map: "idx_monthly_tax_active")
}

model notifications {
  id                                   BigInt   @id @default(autoincrement())
  uuid                                 String   @unique(map: "Notifications_uuid_key") @db.Char(36)
  user_id                              BigInt?
  sender_id                            BigInt?
  target_role                          String?  @db.VarChar(50)
  target_department_id                 BigInt?
  title                                String   @db.VarChar(150)
  message                              String   @db.Text
  type                                 String   @db.VarChar(50)
  reference_id                         String?  @db.Char(36)
  metadata                             Json?
  is_read                              Boolean  @default(false)
  action_taken                         Boolean  @default(false)
  created_at                           DateTime @default(now())
  updated_at                           DateTime
  users_notifications_sender_idTousers users?   @relation("notifications_sender_idTousers", fields: [sender_id], references: [id], map: "Notifications_sender_id_fkey")
  users_notifications_user_idTousers   users?   @relation("notifications_user_idTousers", fields: [user_id], references: [id], map: "Notifications_user_id_fkey")

  @@index([is_read], map: "idx_notification_read")
  @@index([sender_id], map: "idx_notification_sender")
  @@index([user_id], map: "idx_notification_user")
}

model payment_batch_items {
  id               BigInt                     @id @default(autoincrement())
  uuid             String                     @unique(map: "Payment_batch_items_uuid_key") @db.Char(36)
  payment_batch_id BigInt
  employee_id      BigInt
  transaction_id   BigInt
  status           payment_batch_items_status
  rejection_reason String?                    @db.Text
  approved_by      BigInt?
  approved_at      DateTime?
  created_at       DateTime                   @default(now())
  users            users?                     @relation(fields: [approved_by], references: [id], map: "Payment_batch_items_approved_by_fkey")
  employees        employees                  @relation(fields: [employee_id], references: [id], map: "Payment_batch_items_employee_id_fkey")
  payment_batches  payment_batches            @relation(fields: [payment_batch_id], references: [id], map: "Payment_batch_items_payment_batch_id_fkey")
  transactions     transactions               @relation(fields: [transaction_id], references: [id], map: "Payment_batch_items_transaction_id_fkey")

  @@index([approved_by], map: "Payment_batch_items_approved_by_fkey")
  @@index([transaction_id], map: "Payment_batch_items_transaction_id_fkey")
  @@index([payment_batch_id], map: "idx_payment_batch_item_batch")
  @@index([employee_id], map: "idx_payment_batch_item_employee")
}

model payment_batches {
  id                                        BigInt                           @id @default(autoincrement())
  uuid                                      String                           @unique(map: "Payment_batches_uuid_key") @db.Char(36)
  batch_code                                String                           @unique(map: "Payment_batches_batch_code_key") @db.VarChar(100)
  working_location_id                       BigInt
  payroll_month                             Int
  payroll_year                              Int
  total_employees                           Int                              @default(0)
  total_amount                              Decimal                          @default(0.00) @db.Decimal(18, 2)
  total_gross                               Decimal                          @default(0.00) @db.Decimal(18, 2)
  total_allowances                          Decimal                          @default(0.00) @db.Decimal(18, 2)
  total_deductions                          Decimal                          @default(0.00) @db.Decimal(18, 2)
  total_tax                                 Decimal                          @default(0.00) @db.Decimal(18, 2)
  status                                    payment_batches_status
  current_approval_step                     Int                              @default(1)
  rejected_reason                           String?                          @db.Text
  submitted_by                              BigInt
  approved_by                               BigInt?
  submitted_at                              DateTime?
  approved_at                               DateTime?
  created_at                                DateTime                         @default(now())
  updated_at                                DateTime
  ikimina_contributions                     ikimina_contributions[]
  payment_batch_items                       payment_batch_items[]
  users_payment_batches_approved_byTousers  users?                           @relation("payment_batches_approved_byTousers", fields: [approved_by], references: [id], map: "Payment_batches_approved_by_fkey")
  users_payment_batches_submitted_byTousers users                            @relation("payment_batches_submitted_byTousers", fields: [submitted_by], references: [id], map: "Payment_batches_submitted_by_fkey")
  working_locations                         working_locations                @relation(fields: [working_location_id], references: [id], map: "Payment_batches_working_location_id_fkey")
  payroll_batch_approval_actions            payroll_batch_approval_actions[]

  @@index([approved_by], map: "Payment_batches_approved_by_fkey")
